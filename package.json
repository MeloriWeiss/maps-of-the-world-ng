{
  "name": "maps-of-the-world",
  "version": "0.0.0",
  "scripts": {
    "start:web": "nx run web:serve --open",
    "start:api": "nx serve api",
    "start:api-deps:docker": "docker compose --env-file .env -f docker/docker-compose.dev.yml up",
    "build:web": "nx build web",
    "build:api": "nx build api",
    "build:web:prod": "nx build web --prod",
    "build:api:prod": "nx build api --configuration=production",
    "build:api:prod:docker": "docker compose -f docker/docker-compose.prod.yml up",
    "db:main:migrate": "nx run database-main:migrate --name",
    "db:main:generate": "nx run database-main:generate",
    "db:main:seed": "nx run database-main:seed",
    "db:main:push": "nx run database-main:push",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "docs:gen": "rimraf documentation && compodoc -p .compodocrc.json",
    "docs:watch": "compodoc -p .compodocrc.json -s -w --open",
    "watch": "nx build --watch --configuration development",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.15",
