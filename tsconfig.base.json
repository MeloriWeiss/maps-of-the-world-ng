{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "paths": {
      "@wm/api/api-auth": ["libs/api/api-auth/src/index.ts"],
      "@wm/api/database-main": ["libs/api/database-main/src/index.ts"],
      "@wm/web/auth": ["libs/web/auth/src/index.ts"],
      "@wm/web/common-ui": ["libs/web/common-ui/src/index.ts"],
      "@wm/web/data-access/*": ["libs/web/data-access/src/lib/*"],
      "@wm/web/forum": ["libs/web/forum/src/index.ts"],
      "@wm/web/home": ["libs/web/home/src/index.ts"],
      "@wm/web/layout/*": ["libs/web/layout/src/lib/*"],
      "@wm/web/mods": ["libs/web/mods/src/index.ts"],
      "@wm/web/profile": ["libs/web/profile/src/index.ts"],
      "@wm/web/workshop": ["libs/web/workshop/src/index.ts"],
      "@wm/api/users": ["libs/api/users/src/index.ts"],
      "@wm/web/web-shared": ["libs/web/shared/src/index.ts"],
      "@wm/shared/*": ["libs/shared/shared/src/lib/*"],
      "@wm/api/api-shared": ["libs/api/api-shared/src/index.ts"]
    },
    "baseUrl": ".",
    "rootDir": "."
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "exclude": ["node_modules", "tmp"]
}
